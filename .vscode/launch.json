    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Run app.py directly",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "APP_ENV": "local"
